{
  "$schema": "../node_modules/@tauri-apps/cli/schema/acl/capability.json",
  "identifier": "default",
  "description": "Default permissions for Harmolyn",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "deep-link:default",
    "deep-link:allow-register",
    "deep-link:allow-on-open-url",
    "single-instance:default",
    "updater:default",
    "updater:allow-check",
    "updater:allow-download-and-install"
  ]
}
